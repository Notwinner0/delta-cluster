{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "regexManagers": [
    {
      "fileMatch": ["^clusters/delta/.+\\.yaml$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?) currentValue=(?<currentValue>.*?)\\s"
      ],
      "versioningTemplate": "semver"
    }
  ],
  "postUpgradeTasks": {
    "commands": [
      "./scripts/update-manifest.sh {{{depName}}} {{{currentValue}}} {{{newVersion}}}"
    ],
    "fileFilters": ["clusters/delta/**/*.yaml"],
    "executionMode": "branch"
  }
}